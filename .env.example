# URL del servidor con WebSockets (Railway, Render, etc.)
# En desarrollo no hace falta - Vite proxy lo maneja
VITE_SERVER_URL=https://impostor-server.up.railway.app

# Webhook de Discord para el audit log del servidor.
# Obligatorio en producción. Sin esta variable el logger sólo escribe
# a stdout (vía journald). Rotar el webhook requiere reiniciar el
# servicio. NO commitear un valor real -- usar .env (ignorado por git).
AUDIT_WEBHOOK_URL=
