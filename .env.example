# URL del servidor WebSocket. Solo necesaria en desarrollo local
# (cuando Vite hace proxy al backend). En producción el cliente
# siempre conecta al mismo origen (window.location), por lo que
# esta variable se ignora.
# Ejemplo: VITE_SERVER_URL=http://localhost:3001
VITE_SERVER_URL=

# Webhook de Discord para el audit log del servidor.
# Obligatorio en producción. Sin esta variable el logger solo escribe
# a stdout (capturado por journald). Para configurar:
#   1. Crear el webhook en Discord (canal -> Integraciones -> Webhooks)
#   2. Copiar la URL al archivo /etc/default/impostor-web en el server
#      (NO commitear un valor real -- .env esta en .gitignore)
#   3. systemctl daemon-reload && systemctl restart impostor-web
AUDIT_WEBHOOK_URL=
